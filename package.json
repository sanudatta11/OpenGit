{
  "name": "opengit",
  "version": "0.1.0",
  "description": "Lightweight desktop Git UI for local repository workflows.",
  "private": true,
  "type": "module",
  "author": "OpenGit",
  "license": "MIT",
  "main": "out/main/index.js",
  "bin": {
    "opengit": "./scripts/opengit.mjs"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "typecheck:src": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:perf": "OPENGIT_PERF=1 vitest run tests/integration/perf.test.ts",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.59.0",
    "chokidar": "^4.0.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "execa": "^9.4.0",
    "lucide-react": "^0.454.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.14.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
